{
  "name": "provider-adapters",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/provider-adapters/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/node:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/provider-adapters",
        "main": "libs/provider-adapters/src/index.ts",
        "tsConfig": "libs/provider-adapters/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/provider-adapters/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/provider-adapters/**/*.ts"]
      }
    }
  },
  "tags": ["scope:shared", "type:adapters"]
}